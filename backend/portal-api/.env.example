# --- Database (option A: full URL for local dev) ---
DATABASE_URL=postgresql+asyncpg://api_user:password@localhost:5432/electric_curator

# --- Database (option B: individual components for Cloud Run + Secret Manager) ---
# DB_HOST=/cloudsql/project:region:instance
# DB_NAME=electric_curator
# DB_USER=api_user
# DB_PASSWORD=secret

# --- Auth ---
JWT_SECRET_KEY=changeme-use-at-least-32-chars-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
