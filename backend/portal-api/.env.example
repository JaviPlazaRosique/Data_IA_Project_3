# --- Database (option A: full URL for local dev) ---
DATABASE_URL=postgresql+asyncpg://api_user:password@localhost:5432/electric_curator

# --- Database (option B: individual components for Cloud Run + Secret Manager) ---
# DB_HOST=/cloudsql/project:region:instance
# DB_NAME=electric_curator
# DB_USER=api_user
# DB_PASSWORD=secret

# --- Auth (Firebase Auth) ---
# Firebase project that issued the ID tokens (audience for verification).
# Required for token verify; falls back to GOOGLE_CLOUD_PROJECT when empty.
FIREBASE_AUTH_PROJECT_ID=project3grupo3
# Service account JSON path (only needed for firebase-admin Firestore writes
# without ADC). Token verify does NOT need this.
# FIREBASE_CREDENTIALS_JSON=/path/to/sa.json

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- GCP / Pub/Sub ---
GOOGLE_CLOUD_PROJECT=demo-local
PUBSUB_TOPIC_SWIPE_EVENTS=swipe-events
# When set, google-cloud-pubsub client targets the local emulator instead of GCP.
# PUBSUB_EMULATOR_HOST=localhost:8085
